# ─── Adobe OAuth Server-to-Server credentials ────────────────────────────────
# Get these from: https://developer.adobe.com/console → Your Project → Credentials
CLIENT_ID=your_adobe_client_id_here
CLIENT_SECRET=your_adobe_client_secret_here
ORG_ID=YOUR_ORG_ID@AdobeOrg

# OAuth scopes — do not change unless you know what you're doing
SCOPES=AdobeID,openid,read_organizations,additional_info.job_function,additional_info.projectedProductContext,additional_info.roles

# ─── IMPORTANT: Reactor API Access ───────────────────────────────────────────
# The credential above must have "Experience Platform Launch" API added in Adobe
# Developer Console. Without it, all Reactor API calls return api-key-invalid.
#
# Steps to fix:
# 1. Go to https://developer.adobe.com/console
# 2. Open your project → Add API → Experience Platform Launch API
# 3. Select "Server-to-Server" auth → Save
# 4. The same CLIENT_ID/CLIENT_SECRET will then work for Reactor API calls

# ─── Gemini AI (Optional - only for Web UI) ──────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Transport ports ─────────────────────────────────────────────────────────
# Main server port (used by config-server for deployment)
PORT=4000
# HTTP MCP transport port
MCP_HTTP_PORT=4000
# SSE MCP transport port (legacy)
MCP_SSE_PORT=4001
# Web UI port (Gemini chat)
UI_PORT=3000

# ─── CORS Configuration ──────────────────────────────────────────────────────
# Allowed origins for HTTP transport (comma-separated, blank = allow all)
# Examples: https://claude.ai,https://cursor.sh
ALLOWED_ORIGINS=

# ─── Debug mode ───────────────────────────────────────────────────────────────
# Set to true to enable verbose logging
DEBUG=false
